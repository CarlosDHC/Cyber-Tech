rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regras para Usuários (Ver perfil, editar)
    match /users/{userId} {
      allow read, write: if request.auth != null; // Permite leitura para contagem no admin
    }

    // Regras para o Blog (Público pode ler, Admin pode escrever)
    match /blog/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Regras para Desafios (Usuários logados podem ler)
    match /desafios/{desafioId} {
      allow read: if request.auth != null;
      // Se apenas o Admin puder criar/editar desafios, você pode restringir o write depois
      allow write: if request.auth != null; 
    }

    // Regras para Pontuações (Notas dos Desafios)
    match /pontuacoes/{pontuacaoId} {
      // Permite ler, criar e atualizar se o usuário estiver logado
      allow read, create, update: if request.auth != null;
      
      // Se você quiser que o aluno só possa ver/gravar a própria nota, use:
      // allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Regras para Likes
    match /likes/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regras para Admins
    match /admins/{userId} {
      allow read: if request.auth != null;
    }

    // Regras para o Fórum (Posts e Comentários)
    match /forum_posts/{postId} {
      // Permite que usuários logados leiam e criem posts
      allow read, create: if request.auth != null;
      
      // Permite que o Admin (ou o autor do post) possa excluir ou atualizar
      // Nota: Para segurança total, você pode validar se o UID é de um admin
      allow update, delete: if request.auth != null;
    }

    // Regras para o Fórum/Chat
    match /forum_messages/{messageId} {
      allow read, create: if request.auth != null;
      // Opcional: apenas o autor pode deletar sua própria mensagem
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /denuncias/{denunciaId} {
      allow read, write: if request.auth != null;
    }
  }
}